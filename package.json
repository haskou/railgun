{
  "name": "@haskou/railgun",
  "version": "0.1.0",
  "description": "CLI to initialize DDD projects with @haskou/ddd-kernel.",
  "bin": {
    "railgun": "dist/cli.js"
  },
  "man": [
    "./man/railgun.1"
  ],
  "files": [
    "AGENTS.md",
    "LICENSE",
    "dist",
    "logo.jpg",
    "man",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/haskou/railgun.git"
  },
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "lint": "eslint ./src ./tests --ext .ts",
    "pack:dry": "npm pack --dry-run",
    "pretest": "yarn build",
    "start": "node dist/cli.js",
    "test": "jest --passWithNoTests",
    "test:coverage": "jest --coverage --passWithNoTests"
  },
  "keywords": [
    "ddd",
    "cli",
    "haskou"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "prettier": "^3.8.4"
  },
  "devDependencies": {
    "@haskou/eslint-config": "0.2.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.3.5",
    "eslint": "^10.5.0",
    "jest": "^30.2.0",
    "ts-jest": "^29.4.6",
    "typescript": "^6.0.3"
  }
}
